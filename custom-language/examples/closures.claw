# Closures: makeCounter returns a function that remembers its own count
fn makeCounter() {
  let count = 0;
  fn inc() {
    count = count + 1;
    return count;
  }
  return inc;
}
let c = makeCounter();
print c();   # 1
print c();   # 2
print c();   # 3
print "strings " + "concatenate";
print 3 > 2 and 1 < 5;
